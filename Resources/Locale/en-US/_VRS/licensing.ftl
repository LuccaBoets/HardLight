ship-license-required-unlicensed = This item is unlicensed. License it to a ship with an appraisal tool (License mode) before anchoring.
ship-license-required-wrong-ship = This item is licensed to { $ship } and cannot be anchored here.
ship-license-already-licensed-same = This item is already licensed to your ship.
ship-license-already-licensed-other = This item is already licensed to another ship. It must be re-licensed (or hacked) to anchor elsewhere.
ship-license-cannot-afford = Insufficient funds to license this item ({ $fee } spesos required).
ship-license-stamped = Licensed to { $ship } for { $fee } spesos.

# Appraisal tool dual-mode messages
ship-license-tool-mode-appraise = Appraisal tool: Appraise mode.
ship-license-tool-mode-license = Appraisal tool: License mode (bound to { $ship }).
ship-license-tool-no-deed = No ship deed found on your ID. Carry the deed on you (PDA or hand) to enter License mode.
ship-license-tool-confirm = Appraised. License to { $ship } for { $fee } spesos? Click again within 6s to confirm.
