slow-ooc-command-description = Enables or disables OOC slow mode, limiting how often players can send OOC messages.
slow-ooc-command-help = Usage: slowooc | slowooc [true/false] | slowooc [true/false] [seconds]
slow-ooc-command-too-many-arguments-error = Too many arguments.
slow-ooc-command-invalid-argument-error = Invalid argument. Expected true or false.
slow-ooc-command-invalid-interval-error = Invalid interval. Expected a positive number of seconds.
slow-ooc-command-interval-set = OOC slow mode interval set to {$seconds} second(s).
slow-ooc-command-enabled = OOC slow mode enabled. Players may send one message every {$seconds} second(s).
slow-ooc-command-disabled = OOC slow mode disabled.
